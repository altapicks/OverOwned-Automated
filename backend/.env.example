# ── Supabase ─────────────────────────────────────────
# Get these from https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key — KEEP SECRET, backend only

# ── DraftKings polling ───────────────────────────────
DK_POLL_INTERVAL_MINUTES=15
DK_SPORTS=TEN                  # comma-separated. TEN=tennis. Add NBA,MMA later.

# ── Slate type filtering ─────────────────────────────
# Which slate types to ingest. Comma-separated list of: classic, showdown, other.
# Default is Classic-only — matches typical DFS workflow.
DK_SLATE_TYPES=classic

# If true (default), when no Classic slate exists for the day but a Showdown
# does, the Showdown will be ingested as a fallback (flagged is_fallback=true
# in the DB and marked as such in Discord). Useful for finals days where DK
# only runs single-match Showdowns.
DK_FALLBACK_TO_SHOWDOWN=true

# ── Discord notifications (optional but recommended) ─
# Create a webhook in Discord: Server Settings → Integrations → Webhooks → New
DISCORD_WEBHOOK_SLATES=         # fires when new slate detected
DISCORD_WEBHOOK_ERRORS=         # fires when jobs fail

# ── Sentry (optional, recommended for production) ────
SENTRY_DSN=

# ── API ──────────────────────────────────────────────
API_PORT=8000
# Comma-separated list of allowed frontend origins. Include your Vercel URL.
CORS_ORIGINS=http://localhost:5173,https://overowned.vercel.app

# ── Feature flags ────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development          # development | production
